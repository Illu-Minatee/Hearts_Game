<Window x:Class="Hearts_Game.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Hearts_Game"
        mc:Ignorable="d"
        Title="Hearts" Height="720" Width="800" WindowStartupLocation="CenterScreen" Background="Green">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Menu VerticalAlignment="Top">
            <MenuItem Header="Game">
                <MenuItem Header="New Game"></MenuItem>
                <MenuItem Header="Quit Game"></MenuItem>
            </MenuItem>
            <MenuItem Header="Options"></MenuItem>
            <MenuItem Header="Developer">
                <MenuItem Header="X-Ray Cards" IsCheckable="True" Click="OnXRayClick"> </MenuItem>
            </MenuItem>
        </Menu>

        <Grid x:Name="rootGrid" Grid.Row="1">
            <Grid x:Name="zoneOne" Background="Magenta" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,492,0,0">

            </Grid>
            <Grid x:Name="zoneTwo" Background="Magenta" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="32,0,0,0">

            </Grid>
            <Grid x:Name="zoneThree" Background="Magenta" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="652,0,0,0">

            </Grid>
            <Grid x:Name="zoneFour" Background="Magenta" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,8,0,0">

            </Grid>
        </Grid>
    </Grid>
</Window>
