<Window x:Class="Hearts_Game.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Hearts_Game"
        mc:Ignorable="d"
        Title="Hearts"
        Height="720"
        Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="Green"
        KeyDown="OnWindowKeyDown">

    <Grid>          
        <!-- START SCREEN -->
        <Grid x:Name="StartScreen" Background="#0E5F0E" Visibility="Visible">
            <Border Width="420"
                    Padding="30"
                    Background="#DDEBDD"
                    CornerRadius="16"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Hearts"
                               FontSize="34"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,20"/>

                    <TextBlock Text="Enter your player name"
                               FontSize="18"
                               Margin="0,0,0,10"/>

                    <TextBox x:Name="txtPlayerName"
                             Height="38"
                             FontSize="18"
                             Text="Player"
                             Margin="0,0,0,20"/>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,10,0,0">

                        <Button Content="New Game"
                                Width="140"
                                Height="45"
                                Margin="10"
                                Click="OnStartNewGameClick"/>

                        <Button Content="Continue"
                                Width="140"
                                Height="45"
                                Margin="10"
                                Click="OnContinueGameClick"/>

                    </StackPanel>

                </StackPanel>
            </Border>
        </Grid>

        <!-- GAME SCREEN -->
        <Grid x:Name="GameScreen" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Menu Grid.Row="0" VerticalAlignment="Top">
                <MenuItem Header="Game">
                    <MenuItem Header="New Game" Click="OnNewGameClick"/>
                    <MenuItem Header="Quit Game" Click="OnQuitClick"/>
                </MenuItem>

                <MenuItem Header="Options">
                    <MenuItem Header="Card Theme">
                        <MenuItem Header="Red" Click="OnThemeChange" Tag="cardBack_red3.png"/>
                        <MenuItem Header="Blue" Click="OnThemeChange" Tag="cardBack_blue3.png"/>
                        <MenuItem Header="Green" Click="OnThemeChange" Tag="cardBack_green3.png"/>
                    </MenuItem>

                    <MenuItem Header="Score Limit">
                        <MenuItem Header="50 Points" Click="OnScoreLimitChange" Tag="50"/>
                        <MenuItem Header="100 Points" Click="OnScoreLimitChange" Tag="100"/>
                    </MenuItem>
                </MenuItem>
                <MenuItem Header="Developer">
                    <MenuItem Header="X-Ray Cards" IsCheckable="True" Click="OnXRayClick"/>
                </MenuItem>
                <MenuItem Header="Help" Click="OnHelpClick"/>
            </Menu>

            <Grid x:Name="rootGrid" Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="360"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT PANEL -->
                <StackPanel Grid.Column="0"
                            Margin="18,18,12,18"
                            VerticalAlignment="Top"
                            Panel.ZIndex="30">

                    <Border Background="#DDEBDD"
                            CornerRadius="12"
                            Padding="16"
                            Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="Current Player"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Margin="0,0,0,12"/>
                            <TextBlock x:Name="txtCurrentPlayerName"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="Player"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#DDEBDD"
                            CornerRadius="12"
                            Padding="16">
                        <StackPanel>
                            <TextBlock Text="Round Info"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Margin="0,0,0,12"/>

                            <TextBlock x:Name="txtLeadSuit"
                                       FontSize="16"
                                       Margin="0,6,0,0"
                                       Text="Lead Suit: None"/>

                            <TextBlock x:Name="txtHeartsBroken"
                                       FontSize="16"
                                       Margin="0,6,0,0"
                                       Text="Hearts Broken: No"/>

                            <TextBlock x:Name="txtTrickCount"
                                       FontSize="16"
                                       Margin="0,6,0,0"
                                       Text="Trick #: 1"/>
                            
                            <TextBlock x:Name="txtDealer"
                                       FontSize="16"
                                       Margin="0,6,0,0"
                                       Text="Dealer: Player"/>

                            <!-- Cards left for each player -->
                            <TextBlock x:Name="txtSouthCount"
                                       FontSize="16"
                                       Margin="0,6,0,0"
                                       Text="Player Cards: 13"/>

                            <TextBlock x:Name="txtWestCount"
                                       FontSize="16"
                                       Margin="0,6,0,0"
                                       Text="West Cards: 13"/>

                            <TextBlock x:Name="txtNorthCount"
                                       FontSize="16"
                                       Margin="0,6,0,0"
                                       Text="North Cards: 13"/>

                            <TextBlock x:Name="txtEastCount"
                                       FontSize="16"
                                       Margin="0,6,0,0"
                                       Text="East Cards: 13"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- CENTER TABLE AREA -->
                <Grid Grid.Column="1" Margin="10">
                    <Grid x:Name="zoneOne"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Bottom"
                          Margin="0,0,0,65"
                          Panel.ZIndex="5"/>

                    <Grid x:Name="zoneTwo"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Center"
                          Margin="40,0,0,0"
                          Panel.ZIndex="5"/>

                    <Grid x:Name="zoneThree"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Center"
                          Margin="0,0,40,0"
                          Panel.ZIndex="5"/>

                    <Grid x:Name="zoneFour"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Top"
                          Margin="0,25,0,0"
                          Panel.ZIndex="5"/>

                    <Grid x:Name="trickZone"
                          Width="320"
                          Height="270"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Margin="0,-30,0,0"
                          Background="Transparent"
                          Panel.ZIndex="10">
                        <Border BorderBrush="#CCCCCC"
                                BorderThickness="1"
                                Opacity="0.85"
                                CornerRadius="12"
                                Background="#145A14"/>
                        <Grid x:Name="trickCards"/>
                    </Grid>
                </Grid>

                <!-- RIGHT PANEL -->
                <Grid Grid.Column="2" Margin="12,18,18,18" Panel.ZIndex="30">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="#DDEBDD"
                            CornerRadius="12"
                            Padding="16"
                            Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="Scoreboard"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Margin="0,0,0,12"/>

                            <TextBlock x:Name="txtPlayer1Score"
                                       FontSize="16"
                                       Margin="0,5,0,0"
                                       Text="Player: 0"/>

                            <TextBlock x:Name="txtPlayer2Score"
                                       FontSize="16"
                                       Margin="0,5,0,0"
                                       Text="CPU West: 0"/>

                            <TextBlock x:Name="txtPlayer3Score"
                                       FontSize="16"
                                       Margin="0,5,0,0"
                                       Text="CPU North: 0"/>

                            <TextBlock x:Name="txtPlayer4Score"
                                       FontSize="16"
                                       Margin="0,5,0,0"
                                       Text="CPU East: 0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2"
                            Background="#DDEBDD"
                            CornerRadius="12"
                            Padding="16"
                            Height="310">
                        <StackPanel>
                            <TextBlock Text="Game Log"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Margin="0,0,0,12"/>

                            <ListBox x:Name="lstGameLog"
                                     Height="230"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <!-- LOADING OVERLAY -->
        <Grid x:Name="LoadingOverlay"
              Background="#AA000000"
              Visibility="Collapsed"
              Panel.ZIndex="999">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Background="White" Padding="20" CornerRadius="12">
                    <StackPanel>
                        <TextBlock Text="Loading game..."
                                   FontSize="24"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,12"/>
                        <ProgressBar Width="250"
                                     Height="20"
                                     IsIndeterminate="True"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Window>