<UserControl x:Class="Hearts_Game.GameAssets.CardUI"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Hearts_Game.GameAssets"
             mc:Ignorable="d" 
             Height="150" Width="102"
             RenderTransformOrigin="0.5, 0.5"
             Background="Transparent"
             MouseEnter="OnMouseEnter" 
             MouseLeave="OnMouseLeave"
             MouseDown="OnMouseDown">

    <!-- The Border that highlights when you hover -->
    <Border x:Name="SelectionBorder" BorderBrush="Yellow" BorderThickness="0" CornerRadius="8" Background="Transparent">
        <Grid>
            <!-- The Actual Card Image -->
            <Image x:Name="CardImage" Stretch="Fill" />

            <!-- A subtle drop shadow to make it look 3D (Presentation Polish) -->
            <Grid.Effect>
                <DropShadowEffect BlurRadius="5" Direction="320" Opacity="0.5" ShadowDepth="2"/>
            </Grid.Effect>
        </Grid>
    </Border>
</UserControl>

